# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC...

# Base URL of the Jun webapp (NGINX terminates TLS there)
JUN_URL=https://your-host

# Webapp account the bot logs in with. Use the SAME account as the game mod
# and the web UI so all three continue one shared conversation.
JUN_EMAIL=you@example.com
JUN_PASSWORD=change-me

# Conversation to continue. 0 = create one on first run and remember it in
# .conversation_id. Set it to the same id as the mod's [Jun] ConversationId
# to share a single chat across game / web / Telegram.
JUN_CONVERSATION_ID=0

# Optional model override for chat.php (empty = server default)
JUN_MODEL=

# Reasoning effort: auto, low, medium or high
JUN_REASONING=auto

# Comma-separated Telegram user ids allowed to use the bot.
# Find yours by messaging @userinfobot. Do not leave empty on a public bot!
ALLOWED_USER_IDS=

# Set to false only when testing against self-signed HTTPS
JUN_VERIFY_TLS=true
